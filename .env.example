# ──────────────────────────────────────────────────────────────
# .env.example — 실제 배포 시 이 파일을 복사해 .env 로 사용
#   cp .env.example .env
#   vi .env  ← 실제 값으로 채우기
# ──────────────────────────────────────────────────────────────

# EC2 퍼블릭 IP 또는 도메인 (포트 제외)
SERVER_IP=1.2.3.4

# OpenAI API 키
OPENAI_API_KEY=sk-...

# 사용할 모델 (기본값: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# JWT 시크릿 키 — 반드시 강력한 랜덤값으로 교체
# 생성: openssl rand -hex 32
SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32
